# ─── Required ─────────────────────────────────────────────────
PORT=4000
MONGODB_URI=mongodb://localhost:27017/contentpulse
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-random-32-char-string
ENCRYPTION_KEY=change-me-to-a-64-char-hex-string-representing-32-bytes

# ─── Optional ─────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

# ─── Meta OAuth (required for Instagram connector) ───────────
# META_CLIENT_ID=
# META_CLIENT_SECRET=
# META_REDIRECT_URI=http://localhost:4000/api/v1/channels/instagram/callback
# DASHBOARD_URL=http://localhost:5173

# ─── LinkedIn OAuth (required for LinkedIn connector) ────────
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_REDIRECT_URI=http://localhost:4000/api/v1/channels/linkedin/callback
# LINKEDIN_AUTH_URL=https://www.linkedin.com/oauth/v2/authorization
# LINKEDIN_TOKEN_URL=https://www.linkedin.com/oauth/v2/accessToken
# LINKEDIN_USERINFO_URL=https://api.linkedin.com/v2/userinfo
